# Copy this file to .env and fill in your values.

# Hugging Face authentication token (required)
# Get your token at: https://huggingface.co/settings/tokens
HF_TOKEN=your_token_here

# Cache directory for HF models (relative to working directory)
HF_CACHE_DIR=@.hf_cache

# Windows: disable symlinks/hardlinks to avoid permission errors
HF_HUB_DISABLE_SYMLINKS=1
HF_HUB_DISABLE_HARDLINKS=1
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# Flask debug mode (set to True only during local development)
FLASK_DEBUG=False
